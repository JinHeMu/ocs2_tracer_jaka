    [8] "urbase_base_link, Link_5"
    [9] "urbase_base_link, Link_6"

    [10] "base_link, gripper_base_link"
    [11] "urbase_base_link, gripper_base_link"
  }

  collisionObjectPairs { }

  minimumDistance 0.05
  mu 1e-2
  delta 1e-3
}

